// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id              Int               @id @default(autoincrement())
  email           String            @unique
  password        String
  name            String
  bio             String? 
  photo           String?
  lastOnline      DateTime?
  isOnline        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  // friendships i started:
  friendSent      UserFriends[]     @relation("userFriendSent")
  //friendships recieved
  friendsRecieved UserFriends[]     @relation("userFriendReceived")
  //relations
  messages        Message[]
  channels        ChannelMember[]
}
enum FriendshipStatus {
  PENDING
  ACTIVE
  BLOCKED
}
//*note to self be ware of duplicates when queriying
/*
  { userId: 1, friendId: 2 } OR { userId: 2, friendId: 1 }
*/
model UserFriends{
  id          Int               @id @default(autoincrement())
  status      FriendshipStatus  @default(PENDING)
  createdAt   DateTime          @default(now())
  //relations
  userId      Int
  user        User              @relation("userFriendSent", fields: [userId], references: [id])
  
  friendId    Int
  friend      User              @relation("userFriendReceived",fields: [friendId],references: [id])
  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}
enum ChannelType {
  FRIEND
  GROUP
}
model Channel{
  id          Int               @id @default(autoincrement())
  name        String
  createdAt   DateTime          @default(now())
  //relations
  type        ChannelType     @default(FRIEND)
  messages    Message[]
  members     ChannelMember[]
}
model Message{
  id          Int               @id @default(autoincrement())
  content     String
  createdAt   DateTime          @default(now())
  //relations
  channelId   Int
  channel     Channel           @relation(fields: [channelId], references: [id])

  userId      Int
  user        User              @relation(fields: [userId], references: [id])
  //self relation allowing for a reply to message function
  parentId    Int?
  parent      Message?          @relation("messageReplies",fields: [parentId], references: [id])
  
  replies     Message[]         @relation("messageReplies")
}
model ChannelMember{
  id          Int               @id @default(autoincrement())
  isMod       Boolean           @default(false)
  joinedAt    DateTime          @default(now())
  //relations
  userId      Int
  user        User              @relation(fields: [userId], references: [id])

  channelId   Int
  channel     Channel           @relation(fields: [channelId],references: [id])
  @@unique([userId, channelId])
}